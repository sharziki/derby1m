{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://derby1m.com/schemas/field.schema.json",
  "title": "Derby/1M field data",
  "description": "Schema for data/field.json (post-draw) and data/field.example.json (pre-draw). Loaded by lib/field.ts and validated on every request via lib/schema.ts (Zod). This file is the canonical JSON Schema copy for editor autocomplete + external tooling.",
  "type": "object",
  "required": ["meta", "horses"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["race", "date"],
      "additionalProperties": false,
      "properties": {
        "race": { "type": "string", "minLength": 1 },
        "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "distance": { "type": "string" },
        "surface": { "type": "string" },
        "note": { "type": "string" },
        "updated": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "projected_morning_lines": { "type": "boolean" },
        "sources": { "type": "array", "items": { "type": "string" } }
      }
    },
    "horses": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/horse" }
    }
  },
  "$defs": {
    "horse": {
      "type": "object",
      "required": [
        "id",
        "name",
        "post_position",
        "beyer_last_3",
        "running_style",
        "distance_aptitude",
        "class_rating",
        "surface_aptitude_dirt",
        "pace_figure_avg"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,50}$" },
        "name": { "type": "string", "minLength": 1, "maxLength": 60 },
        "post_position": { "type": "integer", "minimum": 1, "maximum": 20 },
        "jockey": { "type": ["string", "null"] },
        "trainer": { "type": ["string", "null"] },
        "morning_line": {
          "type": ["string", "null"],
          "pattern": "^\\d+-\\d+$"
        },
        "beyer_last_3": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "integer", "minimum": 0, "maximum": 140 }
        },
        "running_style": { "enum": ["E", "E/P", "P", "S"] },
        "distance_aptitude": { "type": "number", "minimum": 0, "maximum": 1 },
        "class_rating": { "type": "number", "minimum": 0, "maximum": 10 },
        "surface_aptitude_dirt": { "type": "number", "minimum": 0, "maximum": 1 },
        "surface_aptitude_wet": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "pace_figure_avg": { "type": "number", "minimum": 0 },
        "silk": { "$ref": "#/$defs/silk" }
      }
    },
    "silk": {
      "type": ["object", "null"],
      "required": ["pattern", "primary", "secondary"],
      "additionalProperties": false,
      "properties": {
        "pattern": { "enum": ["solid", "diamonds", "stripes", "quartered", "chevrons", "hoops"] },
        "primary": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
        "secondary": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" }
      }
    }
  }
}
